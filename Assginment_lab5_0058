    "# ── YOUR CODE HERE ─────────────────────────────────────────────\n",
    "# 1. Create a dataset of individual indices\n",
    "char_dataset = tf.data.Dataset.from_tensor_slices(encoded)\n",
    "\n",
    "# 2. Create sequences of length T+1\n",
    "sequences = char_dataset.batch(T + 1, drop_remainder=True)\n",
    "\n",
    "# 3. Split into (input, target) pairs\n",
    "def split_input_target(chunk):\n",
    "    input_text = chunk[:-1]\n",
    "    target_text = chunk[1:]\n",
    "    return input_text, target_text\n",
    "\n",
    "dataset = sequences.map(split_input_target)\n",
    "\n",
    "# 4. Shuffle, Batch, and Prefetch for performance\n",
    "dataset = (\n",
    "    dataset\n",
    "    .shuffle(10000)\n",
    "    .batch(B, drop_remainder=True)\n",
    "    .prefetch(tf.data.AUTOTUNE)\n",
    ")\n",
    "\n",
    "# Verify shapes\n",
    "for x_batch, y_batch in dataset.take(1):\n",
