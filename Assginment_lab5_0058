    "def generate_music(model, seed_notes, note_to_int, int_to_note, n_generate=200, temperature=1.0):\n",
    "    \"\"\"\n",
    "    Generate a sequence of notes using temperature sampling.\n",
    "    x_{t+1} ~ Categorical( softmax( ŷ_t / τ ) )\n",
    "    \"\"\"\n",
    "    # Step 1: Build a generation model (batch_size=1) and copy weights\n",
    "    # We use a T of 100 to match the training data\n",
    "    gen_model = build_music_rnn(vocab_size, d, H, T=100, batch_size=1)\n",
    "    gen_model.set_weights(model.get_weights())\n",
    "\n",
    "    # Step 2: Encode seed_notes as integers\n",
    "    input_eval = [note_to_int[s] for s in seed_notes]\n",
    "    generated_notes = []\n",
    "\n",
    "    # Step 3: Generation Loop\n",
    "    for i in range(n_generate):\n",
    "        # Reshape current sequence to (1, T) for the model\n",
    "        input_tensor = tf.expand_dims(input_eval, 0)\n",
    "        \n",
    "        # Get logits from model\n",
    "        predictions = gen_model(input_tensor)\n",
    "        \n",
    "        # Pull only the logits for the VERY LAST time step\n",
    "        predictions = predictions[:, -1, :]\n",
    "        \n",
    "        # Apply temperature: logits / tau\n",
    "        predictions = predictions / temperature\n",
    "        \n",
    "        # Sample the next note index using a categorical distribution\n",
    "        predicted_id = tf.random.categorical(predictions, num_samples=1)[0, 0].numpy()\n",
    "        \n",
    "        # Append to sequence and slide the window\n",
    "        input_eval = input_eval[1:] + [predicted_id]\n",
    "        generated_notes.append(int_to_note[predicted_id])\n",
    "\n",
    "    return generated_notes\n",
    "\n",
    "print(\"Generation function defined ✓\")"
   ]
