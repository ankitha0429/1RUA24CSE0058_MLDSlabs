    "def build_music_rnn(vocab_size, d, H, T, batch_size=None, stateful=False):\n",
    "    \"\"\"\n",
    "    Build a Khapra-style RNN for music generation.\n",
    "    Architecture: x_t → Embedding(d) → SimpleRNN(H) → Dense(|V|)\n",
    "    \"\"\"\n",
    "    model = keras.Sequential([\n",
    "        # Step 1: Input layer\n",
    "        layers.Input(shape=(T,), batch_size=batch_size),\n",
    "        \n",
    "        # Step 2: Embedding layer (W_embed)\n",
    "        # Maps integer indices to dense vectors of size d\n",
    "        layers.Embedding(input_dim=vocab_size, output_dim=d, name='embedding_W'),\n",
    "        \n",
    "        # Step 3: SimpleRNN layer (Hidden state s_t)\n",
    "        # s_t = tanh(W·e_t + U·s_{t-1} + b_s)\n",
    "        layers.SimpleRNN(units=H, return_sequences=True, stateful=stateful, name='s_t_rnn'),\n",
    "        \n",
    "        # Step 4: Dense layer (Output ŷ_t)\n",
    "        # ŷ_t = V·s_t + b_y\n",
    "        layers.Dense(units=vocab_size, name='y_hat_logits')\n",
    "    ])\n",
    "    \n",
    "    return model\n",
    "\n",
    "# Build and display the model\n",
    "model = build_music_rnn(vocab_size, d, H, T)\n",
    "model.summary()"
   ]
